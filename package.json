  "main": "script.js",
  "scripts": {
    "serve": "npx serve -l 3000",
    "serve:build": "npx serve -l 3000 build",
    "build:blog": "npm run build --prefix blog",
    "build:merge": "node scripts/merge-static.mjs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
